{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://impresso.github.io/impresso-schemas/json/linguistic_annotation/ling_spacy.schema.json",
  "title": "Linguistic Annotation (spaCy)",
  "type": "object",
  "description": "Schema for validation of linguistic annotation as produced by spacy for newspaper data",
  "required": ["ts", "id", "sents"],
  "properties": {
    "ts": {
      "type": "string",
      "title": "The Ts Schema",
      "description": "timestamp",
      "examples": ["2009-06-15T13:45:30"],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "id": {
      "type": "string",
      "title": "The Id Schema",
      "description": "id of text",
      "examples": ["NZZ-1794-07-26-a-i0002"],
      "pattern": "^(.*)$"
    },
    "sents": {
      "type": "array",
      "title": "The Sents Schema",
      "description": "container for sentences (boundaries produced by spacy)",
      "items": {
        "type": "object",
        "title": "The Items Schema",
        "required": ["tok"],
        "properties": {
          "sid": {
            "type": "integer",
            "title": "The Sid Schema",
            "description": "Sentence ids",
            "examples": [1]
          },
          "lg": {
            "type": "string",
            "title": "The Lg Schema",
            "description": "ISO language identifier",
            "examples": ["de"]
          },
          "tok": {
            "type": "array",
            "title": "The Tok Schema",
            "description": "container for tokens",
            "items": {
              "type": "object",
              "title": "The Items Schema",
              "required": ["t", "o"],
              "properties": {
                "t": {
                  "type": "string",
                  "title": "The T Schema",
                  "description": "token text",
                  "examples": ["Kumpel"],
                  "pattern": "^(.*)$"
                },
                "l": {
                  "type": "string",
                  "title": "The L Schema",
                  "description": "token lemma",
                  "examples": ["Kumpel"],
                  "pattern": "^(.*)$"
                },
                "p": {
                  "type": "string",
                  "title": "The P Schema",
                  "description": "part-of-speech assigned to token from spacy",
                  "examples": ["NOUN"],
                  "pattern": "^(.*)$"
                },
                "o": {
                  "type": "integer",
                  "title": "The O Schema",
                  "description": "zero-based character offset corresponding to position in ft element",
                  "examples": [0]
                },
                "e": {
                  "type": "string",
                  "title": "The E Schema",
                  "description": "named entity type with information about position according to IOB schema",
                  "examples": ["B-LOC"],
                  "pattern": "^(.*)$"
                }
              }
            }
          }
        }
      }
    }
  }
}
