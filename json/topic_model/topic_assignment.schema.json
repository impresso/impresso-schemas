{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://impresso.github.io/impresso-schemas/json/topic_model/topic_assignment.schema.json",
  "description": "A representation for the probabilistic assignments of the topics of a topic model to content items.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the content item.",
      "examples": ["actionfem-1940-01-08-a-i0001"]
    },
    "ts": {
      "$id": "#/properties/ts",
      "type": "string",
      "title": "The Ts Schema",
      "description": "timestamp",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "lg": {
      "type": "string",
      "description": "https://en.wikipedia.org/wiki/List_of_ISO_639-2_codes"
    },
    "topic_model": {
      "type": "string",
      "description": "internal symbolic name of the model, starts with tm"
    },
    "model_id": {
      "type": "string",
      "description": "internal symbolic name of the model, starts with tm"
    },
    "topics_git": {
      "type": "string",
      "description": "git describe of the repository code used to generate the topics"
    },
    "topic_count": {
      "type": "integer",
      "description": "The number of topics in the topic model"
    },
    "min_p": {
      "type": "number",
      "description": "The minimum proportion threshold of a topic in the document to be included in the output.",
      "minimum": 0,
      "maximum": 1
    },
    "topics": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/topic"
      },

      "description": "Sparse representation of topics"
    }
  },
  "required": ["lg", "topics", "topic_count", "topic_model", "id"],
  "definitions": {
    "topic": {
      "description": "The probability/proportion of a topic in the document",
      "type": "object",
      "properties": {
        "p": {
          "type": "number",
          "description": "Probability or proportion of topic",
          "minimum": 0,
          "maximum": 1
        },
        "t": {
          "type": ["integer", "string"],
          "description": "Topic id "
        }
      },
      "required": ["p", "t"]
    }
  }
}
